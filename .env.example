# GitHub — fine-grained PAT with repo-issues:write on the target repo
GITHUB_REPORT_TOKEN=
GITHUB_REPORT_REPO_OWNER=code-yeongyu
GITHUB_REPORT_REPO_NAME=oh-my-openagent

# Cloudflare Turnstile (free) — https://developers.cloudflare.com/turnstile
# For local verification use the "always passes" test keys:
#   site key:   1x00000000000000000000AA
#   secret key: 1x0000000000000000000000000000000AA
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Optional Upstash Redis / Ratelimit backing for spam control
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Optional support/report form flag. Set to 1 only after configuring GitHub, Turnstile, and KV env vars.
NEXT_PUBLIC_ENABLE_SUPPORT=
